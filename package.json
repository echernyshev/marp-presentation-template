{
  "name": "create-marp-presentation",
  "version": "1.2.3",
  "description": "Create a new Marp presentation project with one command. Manage themes quickly and easily with the CLI.",
  "bin": {
    "create-marp-presentation": "index.js"
  },
  "files": [
    "index.js",
    "cli/",
    "lib/",
    "docs/",
    "template/",
    "template-optional/",
    "themes/",
    "examples/"
  ],
  "scripts": {
    "test": "jest"
  },
  "keywords": [
    "marp",
    "presentation",
    "markdown",
    "slides",
    "template",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/echernyshev/marp-presentation-template.git"
  },
  "homepage": "https://github.com/echernyshev/marp-presentation-template#readme",
  "bugs": {
    "url": "https://github.com/echernyshev/marp-presentation-template/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "maxWorkers": 1,
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"]
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
